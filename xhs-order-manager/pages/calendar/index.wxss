/* pages/calendar/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; }

.month-nav { display: flex; align-items: center; justify-content: center; gap: 40rpx; padding: 30rpx 0 20rpx; background: #fff; position: sticky; top: 0; z-index: 10; }
.nav-btn { font-size: 44rpx; color: #666; padding: 0 20rpx; }
.month-title { font-size: 34rpx; font-weight: 600; color: #333; }

.week-header { display: flex; background: #FAFAFA; border-bottom: 1rpx solid #EEE; }
.week-day { flex: 1; text-align: center; font-size: 24rpx; color: #999; padding: 14rpx 0; }

.calendar-grid { display: flex; flex-wrap: wrap; padding: 8rpx; background: #fff; }
.cal-cell { width: calc(100% / 7); min-height: 200rpx; display: flex; flex-direction: column; align-items: center; justify-content: flex-start; padding: 6rpx 4rpx; box-sizing: border-box; border-radius: 10rpx; margin: 2rpx 1rpx; position: relative; }
.cal-cell.empty { min-height: 200rpx; }
.cal-cell.selected { background: #FFF1F0; }
.cal-cell.today .day-num { 
  display: inline-block; width: 44rpx; height: 44rpx; line-height: 44rpx; text-align: center;
  background: #FF2442; color: #fff !important; border-radius: 50%; font-size: 22rpx; font-weight: 600;
}
.day-num { font-size: 26rpx; color: #333; flex-shrink: 0; }

/* 日历格子内商单信息 */
.cal-order-info { width: 100%; overflow: hidden; }
.cal-line1 { margin-top: 2rpx; width: 100%; }
.cal-brand { font-size: 20rpx; color: #333; font-weight: 500; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-line2 { margin-top: 2rpx; width: 100%; display: flex; align-items: center; }
.cal-tag { font-size: 18rpx; color: #fff; padding: 0 6rpx; border-radius: 6rpx; line-height: 28rpx; white-space: nowrap; flex-shrink: 0; }
.cal-line3 { margin-top: 2rpx; width: 100%; }
.cal-content { font-size: 18rpx; color: #666; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-line4 { margin-top: 2rpx; width: 100%; }
.cal-compete { font-size: 18rpx; color: #1890FF; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.cal-line5 { margin-top: 2rpx; width: 100%; }
.cal-notes { font-size: 17rpx; color: #999; display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

/* 进度标签颜色 */
.prog-scheduled{background:#F0F0F0;color:#666;} .prog-sent{background:#E6F7FF;color:#1890FF;}
.prog-content{background:#FFF7E6;color:#FA8C16;} .prog-product{background:#F6FFED;color:#52C41A;}
.prog-shot{background:#F9F0FF;color:#722ED1;} .prog-draft{background:#FFF1F0;color:#FF4D4F;}
.prog-finalized{background:#E6F7FF;color:#096DD9;} .prog-published{background:#F6FFED;color:#389E0D;}
.prog-abnormal{background:#FFFBE6;color:#D48806;}

.dot-wrap { display: flex; align-items: center; justify-content: center; gap: 4rpx; margin-top: 4rpx; }
.order-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #FF2442; }
.order-count { font-size: 18rpx; color: #FF2442; margin-left: 2rpx; }

/* 当日详情 */
.day-detail { margin: 20rpx; background: #fff; border-radius: 16rpx; overflow: hidden; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.detail-title { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 24rpx 16rpx; font-size: 30rpx; font-weight: 600; border-bottom: 1rpx solid #F0F0F0; }
.add-for-date { font-size: 24rpx; color: #FF2442; padding: 8rpx 20rpx; background: #FFF1F0; border-radius: 20rpx; }

.day-order-list { max-height: 60vh; }
.day-order-card { padding: 20rpx 24rpx; border-bottom: 1rpx solid #F8F8F8; }

/* 三行布局 */
.doc-row1 { display: flex; justify-content: space-between; align-items: center; }
.doc-brand-product { font-size: 30rpx; font-weight: 500; color: #333; flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.doc-row2 { margin-top: 6rpx; }
.doc-content-type { font-size: 24rpx; color: #666; }
.doc-row3 { margin-top: 4rpx; }
.doc-competition { font-size: 24rpx; color: #1890FF; }
.doc-bottom { display: flex; gap: 24rpx; margin-top: 10rpx; }
.doc-price { font-size: 28rpx; color: #FF2442; font-weight: 600; }
.doc-profit { font-size: 24rpx; }
.adjust-bar { margin-top: 12rpx; padding-top: 10rpx; border-top: 1rpx dashed #EEE; text-align: right; }
.adjust-btn { font-size: 22rpx; color: #1890FF; }

.empty-detail { text-align: center; padding: 60rpx 20rpx; }
.empty-detail .empty-text { color: #bbb; font-size: 26rpx; }
.add-for-date-btn { display: inline-block; margin-top: 16rpx; padding: 12rpx 32rpx; background: #FF2442; color: #fff; border-radius: 30rpx; font-size: 26rpx; }
