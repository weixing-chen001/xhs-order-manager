/* pages/rebate/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; }

/* 统计栏 */
.stats-bar {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  display: flex;
  padding: 32rpx 24rpx;
  gap: 0;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-item.highlight {
  border-left: 1rpx solid rgba(255,255,255,0.2);
  border-right: 1rpx solid rgba(255,255,255,0.2);
}

.stat-val {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
}

.stat-val.green { color: #a8ffc4; }
.stat-val.orange { color: #ffe08a; }

.stat-name {
  font-size: 22rpx;
  color: rgba(255,255,255,0.75);
  margin-top: 8rpx;
}

/* 操作按钮 */
.action-bar {
  padding: 20rpx 24rpx;
}

.add-rebate-btn {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #fff;
  border-radius: 12rpx;
  text-align: center;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 返点列表 */
.rebate-list { padding: 0 0 40rpx; }

.rebate-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  margin: 0 24rpx 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.rebate-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.rebate-brand {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
}

.rebate-amount {
  font-size: 36rpx;
  font-weight: 700;
}

.rebate-info {
  font-size: 22rpx;
  margin-bottom: 16rpx;
}

.rebate-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.rebate-actions {
  display: flex;
  gap: 12rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.action-btn.green-btn { background: #f6ffed; color: #52c41a; }
.action-btn.edit-btn  { background: #e6f7ff; color: #1890ff; }
.action-btn.del-btn   { background: #fff2f0; color: #ff4d4f; }

.rebate-notes {
  font-size: 22rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f5f5f5;
}

/* 表单 */
.form-group { margin-bottom: 24rpx; }
.form-label {
  font-size: 26rpx; color: #555; margin-bottom: 12rpx; display: block;
}
.form-label.required::before { content: '* '; color: #FF2442; }
.form-input {
  width: 100%; height: 80rpx; background: #f8f8f8;
  border-radius: 10rpx; padding: 0 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box;
}
.picker-view {
  display: flex; align-items: center; justify-content: space-between;
  background: #f8f8f8; border-radius: 10rpx; padding: 0 20rpx;
  height: 80rpx; font-size: 28rpx; color: #333;
}
.picker-arrow { color: #ccc; font-size: 36rpx; }

.input-prefix-wrap {
  display: flex; align-items: center;
  background: #f8f8f8; border-radius: 10rpx;
}
.input-prefix { padding: 0 16rpx 0 20rpx; font-size: 30rpx; font-weight: 700; color: #FF2442; }
.input-with-prefix { flex: 1; background: transparent; padding-left: 0; }

.input-suffix-wrap {
  display: flex; align-items: center;
  background: #f8f8f8; border-radius: 10rpx;
}
.input-suffix { padding: 0 20rpx; font-size: 28rpx; color: #666; }

.input-with-picker { display: flex; gap: 16rpx; align-items: center; }
.input-with-picker .form-input { flex: 1; }
.pick-btn {
  background: #fff0f3; color: #FF2442; border-radius: 10rpx;
  padding: 0 20rpx; height: 80rpx; line-height: 80rpx;
  font-size: 22rpx; font-weight: 600; white-space: nowrap;
}

/* 弹窗 */
.modal-mask {
  position: fixed; top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5); z-index: 100;
}
.modal-panel {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: #fff; border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx 60rpx; z-index: 101;
}
.modal-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 28rpx;
}
.modal-title { font-size: 32rpx; font-weight: 700; color: #333; }
.modal-close { font-size: 36rpx; color: #999; }
.modal-btns { display: flex; gap: 20rpx; margin-top: 28rpx; }
.modal-btn {
  flex: 1; height: 88rpx; border-radius: 44rpx;
  text-align: center; line-height: 88rpx; font-size: 28rpx; font-weight: 600;
}
.modal-btn.cancel { background: #f5f5f5; color: #666; }
.modal-btn.confirm { background: linear-gradient(135deg, #FF2442, #FF6B81); color: #fff; }
