/* pages/brands/list/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; }

.search-bar { display: flex; padding: 20rpx; gap: 16rpx; background: #fff; align-items: center; position: sticky; top:0; z-index:10; }
.search-input-wrap { flex:1; display:flex; align-items:center; background:#F8F8F8; border-radius:12rpx; height:72rpx; padding:0 20rpx; }
.search-icon { font-size:28rpx; margin-right:10rpx; }
.search-input { flex:1; height:72rpx; font-size:28rpx; }
.add-btn { white-space:nowrap; height:68rpx; line-height:68rpx; padding:0 24rpx; background:#FF2442; color:#fff; border-radius:12rpx; font-size:26rpx; font-weight:500; }

.export-bar { padding:0 20rpx 16rpx; }
.export-btn { text-align:center; padding:18rpx; background:#FFF7E6; color:#D48806; border-radius:12rpx; font-size:26rpx; font-weight:500; }

.brand-list { padding:0 20rpx; }
.brand-card { display:flex; align-items:center; gap:20rpx; padding:24rpx 20rpx; background:#fff; border-radius:14rpx; margin-bottom:16rpx; box-shadow:0 2rpx 8rpx rgba(0,0,0,.03); }
.brand-avatar { width:80rpx; height:80rpx; border-radius:50%; background:linear-gradient(135deg,#FF2442,#FF6B81); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.avatar-text { font-size:34rpx; color:#fff; font-weight:700; }

.brand-info { flex:1; min-width:0; }
.brand-name-row { display:flex; align-items:center; gap:12rpx; margin-bottom:6rpx; }
.brand-name { font-size:30rpx; font-weight:600; color:#333; overflow:hidden;text-overflow:ellipsis;white-space:nowrap; max-width:280rpx; }
.brand-industry { font-size:22rpx; color:#999; background:#F5F5F5; padding:2rpx 12rpx; border-radius:8rpx; white-space:nowrap; }

.contact-info { display:flex; align-items:center; gap:8rpx; margin-bottom:4rpx; font-size:24rpx; }
.contact-icon { font-size:24rpx; }
.contact-name { color:#555; }
.contact-phone { color:#888; }

.brand-stats { display:flex; align-items:center; gap:8rpx; margin-top:8rpx; }
.stat-text { font-size:22rpx; color:#666; }
.stat-sep { color:#DDD; }
.text-money { color:#FF2442; font-weight:600; }

.brand-action { flex-shrink:0; }
.more-icon { font-size:36rpx; color:#CCC; }

.empty-state { display:flex; flex-direction:column; align-items:center; padding:120rpx 40rpx; }
.empty-icon { font-size:80rpx; }
.empty-text { font-size:32rpx; color:#666; margin-top:20rpx; }
.empty-sub { font-size:26rpx; color:#bbb; margin-top:10rpx; }
