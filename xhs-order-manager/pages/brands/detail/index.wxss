/* pages/brands/detail/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; }

.section-card {
  background: #fff; border-radius: 20rpx;
  padding: 32rpx; margin: 20rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx; font-weight: 700; color: #333;
  margin-bottom: 24rpx; padding-bottom: 16rpx;
  border-bottom: 2rpx solid #fff5f6;
}

.form-group { margin-bottom: 24rpx; }
.form-group:last-child { margin-bottom: 0; }
.form-label { font-size: 26rpx; color: #555; margin-bottom: 12rpx; display: block; }
.form-label.required::before { content: '* '; color: #FF2442; }

.form-input {
  width: 100%; height: 80rpx; background: #f8f8f8;
  border-radius: 10rpx; padding: 0 20rpx; font-size: 28rpx; color: #333; box-sizing: border-box;
}

.form-textarea {
  width: 100%; min-height: 120rpx; background: #f8f8f8;
  border-radius: 10rpx; padding: 16rpx 20rpx; font-size: 28rpx;
  color: #333; box-sizing: border-box; line-height: 1.6;
}

.picker-view {
  display: flex; align-items: center; justify-content: space-between;
  background: #f8f8f8; border-radius: 10rpx; padding: 0 20rpx;
  height: 80rpx; font-size: 28rpx; color: #333;
}
.picker-arrow { color: #ccc; font-size: 36rpx; }

.input-with-copy {
  display: flex; align-items: center; gap: 16rpx;
}
.input-with-copy .form-input { flex: 1; }

.copy-inline {
  background: #f5f5f5; color: #666; border-radius: 8rpx;
  padding: 0 20rpx; height: 80rpx; line-height: 80rpx;
  font-size: 24rpx; flex-shrink: 0;
}

.call-inline {
  background: #e6f7ff; color: #1890ff; border-radius: 8rpx;
  padding: 0 20rpx; height: 80rpx; line-height: 80rpx;
  font-size: 24rpx; flex-shrink: 0; font-weight: 600;
}

.input-suffix-wrap {
  display: flex; align-items: center;
  background: #f8f8f8; border-radius: 10rpx;
}
.input-suffix { padding: 0 20rpx; font-size: 28rpx; color: #666; }

/* 订单列表 */
.order-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}
.order-item:last-child { border-bottom: none; }

.order-row {
  display: flex; justify-content: space-between;
  align-items: center; margin-bottom: 8rpx;
}

.order-content { font-size: 28rpx; color: #333; font-weight: 600; }
.order-price { font-size: 28rpx; font-weight: 700; }
.order-meta { font-size: 22rpx; }

/* 操作按钮 */
.action-area { padding: 32rpx 24rpx 60rpx; }

.btn-save {
  width: 100%; height: 96rpx; line-height: 96rpx;
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #fff; border-radius: 48rpx; font-size: 32rpx;
  font-weight: 700; border: none; margin-bottom: 20rpx;
}

.btn-delete {
  width: 100%; height: 88rpx; line-height: 88rpx;
  background: #fff; color: #ff4d4f; border: 2rpx solid #ff4d4f;
  border-radius: 44rpx; font-size: 28rpx; font-weight: 600;
}
