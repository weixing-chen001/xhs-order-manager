/* pages/index/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; padding-bottom: 20rpx; }

.header { background: linear-gradient(135deg, #FF2442, #FF6B81); padding: 40rpx 30rpx 50rpx; display: flex; align-items: center; justify-content: space-between; }
.header-title { font-size: 44rpx; font-weight: 700; color: #fff; }
.header-sub { font-size: 24rpx; color: rgba(255,255,255,.7); margin-top: 8rpx; }
.header-add { width: 64rpx; height: 64rpx; border-radius: 50%; background: rgba(255,255,255,.25); display: flex; align-items: center; justify-content: center; }
.add-icon { font-size: 36rpx; color: #fff; font-weight: 300; }

/* 卡片 */
.card { margin: 20rpx; padding: 28rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.card-title { font-size: 32rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }
.card-more { font-size: 24rpx; }
.flex-between { display: flex; justify-content: space-between; align-items: center; }

.text-primary { color: #FF2442; }
.text-money { color: #FF2442; font-weight: 600; }
.text-money-large { color: #FF2442; font-size: 52rpx; font-weight: 700; }
.text-gray { color: #999; font-size: 24rpx; }

/* 快速录入表单 */
.quick-entry-card { padding-bottom: 10rpx; }
.form-row { display: flex; gap: 16rpx; margin-bottom: 18rpx; flex-wrap: wrap; }
.two-col > view { flex: 1; min-width: 0; }
.three-col > view { flex: 1; min-width: 0; }
.four-col > view { flex: 1; min-width: 0; }
.form-item { display: flex; flex-direction: column; gap: 6rpx; }
.field-label { font-size: 24rpx; color: #666; font-weight: 500; }
.field-label.required::before { content: '*'; color: #FF2442; margin-right: 4rpx; }

.quick-input {
  height: 68rpx; background: #f8f8f8; border-radius: 12rpx;
  padding: 0 16rpx; font-size: 26rpx; color: #333;
}
.quick-picker {
  height: 68rpx; line-height: 68rpx; background: #f8f8f8; border-radius: 12rpx;
  padding: 0 16rpx; font-size: 24rpx; color: #999;
}

.input-prefix-wrap { position: relative; display: flex; align-items: center; }
.input-prefix-wrap .prefix { position: absolute; left: 14rpx; font-size: 24rpx; color: #999; z-index: 1; }
.prefix-in { padding-left: 36rpx !important; }
.input-prefix-wrap.sm .quick-input { height: 68rpx; font-size: 24rpx; }

.quick-submit-btn {
  height: 68rpx; line-height: 68rpx; text-align: center; background: #FF2442; color: #fff;
  border-radius: 12rpx; font-size: 26rpx; font-weight: 600;
}

.col-sm { flex: 1 !important; }
.col-xs { flex: 1 !important; }
.btn-col { display: flex; align-items: flex-end; }

/* 利润概览 */
.profit-overview { background: linear-gradient(135deg, #FFF5F5, #FFF); border-left: 8rpx solid #FF2442; }
.profit-header { display: flex; align-items: baseline; gap: 16rpx; }
.profit-hint { font-size: 22rpx; }
.profit-num { margin: 16rpx 0 12rpx; }
.profit-meta { display: flex; align-items: center; gap: 8rpx; font-size: 24rpx; }
.meta-item { color: #666; }
.meta-sep { color: #ddd; }
.meta-abnormal { color: #FAAD14; }

/* 近期/最近列表 */
.upcoming-list { display: flex; flex-direction: column; gap: 16rpx; }
.upcoming-item { padding: 16rpx; background: #fafafa; border-radius: 12rpx; }
.upcoming-brand { font-size: 28rpx; font-weight: 500; color: #333; }
.upcoming-info { font-size: 24rpx; margin-top: 6rpx; display: flex; align-items: center; gap: 12rpx; }
.days-badge { padding: 2rpx 12rpx; border-radius: 6rpx; background: #E6F7FF; color: #1890FF; font-size: 22rpx; }
.days-badge.urgent { background: #FFF1F0; color: #FF4D4F; }

.recent-list { display: flex; flex-direction: column; gap: 16rpx; }
.recent-item { padding: 20rpx 16rpx; background: #fafafa; border-radius: 12rpx; }
.recent-top { display: flex; justify-content: space-between; align-items: center; }
.recent-brand { font-size: 28rpx; font-weight: 500; color: #333; }
.recent-price { font-size: 28rpx; color: #FF2442; font-weight: 600; }
.recent-bottom { display: flex; justify-content: space-between; align-items: center; margin-top: 10rpx; }
.recent-profit { font-size: 24rpx; color: #666; margin-top: 8rpx; }

/* 标签 */
.tag { display: inline-block; padding: 4rpx 16rpx; border-radius: 8rpx; font-size: 22rpx; font-weight: 500; }
.tag-pending, .prog-scheduled   { background: #F0F0F0; color: #666; }
.tag-confirmed, .prog-sent     { background: #E6F7FF; color: #1890FF; }
.tag-shooting, .prog-content   { background: #FFF7E6; color: #FA8C16; }
.tag-published, .prog-product  { background: #F6FFED; color: #52C41A; }
.tag-settled, .prog-shot       { background: #F9F0FF; color: #722ED1; }
.tag-cancelled, .prog-draft    { background: #FFF1F0; color: #FF4D4F; }
.prog-finalized                { background: #E6F7FF; color: #096DD9; }
.prog-published                { background: #F6FFED; color: #389E0D; }
.prog-abnormal                 { background: #FFFBE6; color: #D48806; }

/* 空状态 */
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 120rpx 40rpx; }
.empty-icon { font-size: 80rpx; }
.empty-text { font-size: 32rpx; color: #666; margin-top: 20rpx; }
.empty-sub { font-size: 26rpx; color: #bbb; margin-top: 10rpx; }
