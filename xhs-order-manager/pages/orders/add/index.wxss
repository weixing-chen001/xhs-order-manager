/* pages/orders/add/index.wxss */
.page-container { min-height: 100vh; background: #f5f5f5; }
.form-scroll { height: 100vh; }

.section-card { margin: 20rpx; padding: 28rpx; background: #fff; border-radius: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,.04); }
.section-title { font-size: 30rpx; font-weight: 600; color: #333; margin-bottom: 24rpx; }

.form-group { margin-bottom: 22rpx; }
.form-label { font-size: 26rpx; color: #666; margin-bottom: 10rpx; font-weight: 500; }
.form-label.required::before { content:'*'; color:#FF2442; margin-right:4rpx; }
.form-input {
  height: 76rpx; background: #F8F8F8; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; color: #333;
}
.form-textarea {
  width: 100%; height: 160rpx; background: #F8F8F8; border-radius: 12rpx;
  padding: 20rpx 24rpx; font-size: 28rpx; box-sizing: border-box;
}

.input-prefix-wrap { position: relative; display: flex; align-items: center; }
.input-suffix-wrap { position: relative; display: flex; align-items: center; }
.input-prefix, .input-suffix { position: absolute; z-index: 1; font-size: 26rpx; color: #999; }
.input-prefix { left: 20rpx; }
.input-suffix { right: 20rpx; }
.input-with-prefix { padding-left: 48rpx !important; }
.input-with-suffix { padding-right: 48rpx !important; }

.input-with-picker { display: flex; gap: 12rpx; align-items: center; }
.pick-btn { white-space: nowrap; padding: 8rpx 20rpx; background: #FF2442; color: #fff; border-radius: 8rpx; font-size: 24rpx; }

.picker-view {
  height: 76rpx; line-height: 76rpx; background: #F8F8F8; border-radius: 12rpx;
  padding: 0 24rpx; font-size: 28rpx; color: #333; display: flex; justify-content: space-between;
}
.picker-lg .picker-view { font-size: 30rpx; font-weight: 500; }
.picker-arrow { color: #CCC; }

.form-row { display: flex; gap: 16rpx; }
.form-row .form-group { flex: 1; min-width: 0; }
.two-col > view { flex: 1; min-width: 0; }

.profit-preview { margin-top: 16rpx; padding: 20rpx; background: #FFF9F5; border-radius: 12rpx; border-left: 6rpx solid #FF2442; }
.preview-title { font-size: 26rpx; font-weight: 600; color: #333; margin-bottom: 14rpx; }
.preview-grid { display: flex; gap: 24rpx; }
.pv-item { flex: 1; text-align: center; }
.pv-label { display: block; font-size: 22rpx; color: #999; margin-bottom: 4rpx; }
.pv-val { display: block; font-size: 32rpx; color: #FF2442; font-weight: 700; }
.pv-val.small { font-size: 26rpx; }

.submit-area { padding: 30rpx 20rpx 60rpx; }
.submit-btn { width: 100%; height: 88rpx; line-height: 88rpx; border-radius: 44rpx; background: linear-gradient(135deg, #FF2442, #FF6B81); color: #fff; font-size: 32rpx; font-weight: 600; border: none; }
.btn-primary::after { border: none; }
