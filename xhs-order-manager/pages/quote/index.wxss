/* pages/quote/index.wxss */
.page-container {
  min-height: 100vh;
  background: #f5f5f5;
}

.section-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.calc-desc {
  font-size: 24rpx;
  margin-bottom: 4rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 12rpx;
  display: block;
}

.form-label.required::before {
  content: '* ';
  color: #FF2442;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.picker-view {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #f8f8f8;
  border-radius: 10rpx;
  padding: 0 20rpx;
  height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.picker-arrow { color: #ccc; font-size: 36rpx; }

.two-col {
  display: flex;
  gap: 20rpx;
}

.two-col .col {
  flex: 1;
}

.input-prefix-wrap {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 10rpx;
}

.input-prefix {
  padding: 0 16rpx 0 20rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #FF2442;
}

.input-with-prefix {
  flex: 1;
  background: transparent;
  padding-left: 0;
}

/* 结果卡片 */
.result-card {
  background: linear-gradient(135deg, #fff5f6, #fff);
  border-radius: 20rpx;
  padding: 32rpx;
  margin: 20rpx 24rpx 0;
  border: 2rpx solid #ffe0e4;
}

.result-main {
  text-align: center;
  margin-bottom: 24rpx;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.result-price {
  font-size: 72rpx;
  font-weight: 800;
  line-height: 1.1;
}

.result-range {
  font-size: 24rpx;
  margin-top: 8rpx;
}

.result-detail {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.detail-row-sm {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.detail-row-sm:last-child { border-bottom: none; }

.dr-label { font-size: 24rpx; color: #999; }
.dr-value { font-size: 24rpx; color: #333; font-weight: 600; }

.copy-quote-btn {
  text-align: center;
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #fff;
  border-radius: 40rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 模板列表 */
.template-list {}

.template-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.template-item:last-child { border-bottom: none; }

.tpl-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.tpl-desc {
  font-size: 22rpx;
  margin-top: 4rpx;
}

.tpl-right {
  text-align: right;
}

.tpl-price {
  font-size: 32rpx;
  font-weight: 700;
}

.tpl-del {
  font-size: 20rpx;
  color: #ff4d4f;
  background: #fff2f0;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
  display: inline-block;
}

/* 说明 */
.tip-list {}
.tip-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}
.tip-item:last-child { border-bottom: none; }
.tip-icon { font-size: 28rpx; width: 40rpx; }
.tip-text { font-size: 24rpx; color: #666; }

/* 添加模板 */
.add-template-area {
  padding: 28rpx 24rpx 0;
}

.add-tpl-btn {
  text-align: center;
  background: #fff;
  color: #FF2442;
  border: 2rpx dashed #FF2442;
  border-radius: 12rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 100;
}

.modal-panel {
  position: fixed;
  bottom: 0; left: 0; right: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 40rpx 32rpx 60rpx;
  z-index: 101;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  text-align: center;
  line-height: 88rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.modal-btn.cancel {
  background: #f5f5f5;
  color: #666;
}

.modal-btn.confirm {
  background: linear-gradient(135deg, #FF2442, #FF6B81);
  color: #fff;
}
