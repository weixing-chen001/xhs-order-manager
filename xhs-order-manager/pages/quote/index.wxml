<view class="page-container">
  <scroll-view scroll-y>
    <!-- 报价计算器 -->
    <view class="section-card">
      <view class="section-title">💰 报价计算器</view>
      <view class="calc-desc text-gray">根据粉丝数、互动率、内容类型智能估算合理报价区间</view>

      <view class="form-group" style="margin-top:24rpx">
        <view class="form-label required">基础报价（元）</view>
        <view class="input-prefix-wrap">
          <text class="input-prefix">¥</text>
          <input class="form-input input-with-prefix"
                 type="digit"
                 placeholder="你的基础报价"
                 value="{{basePrice}}"
                 bindinput="onBasePriceInput" />
        </view>
      </view>

      <view class="form-group">
        <view class="form-label">内容类型</view>
        <picker mode="selector" range="{{contentTypes}}" value="{{contentTypeIdx}}" bindchange="onContentTypeChange">
          <view class="picker-view">
            <text>{{contentType}}</text>
            <text class="picker-arrow">›</text>
          </view>
        </picker>
      </view>

      <view class="two-col">
        <view class="form-group col">
          <view class="form-label">粉丝数</view>
          <input class="form-input"
                 type="number"
                 placeholder="如：100000"
                 value="{{followers}}"
                 bindinput="onFollowersInput" />
        </view>
        <view class="form-group col">
          <view class="form-label">互动率（%）</view>
          <input class="form-input"
                 type="digit"
                 placeholder="如：3.5"
                 value="{{engagementRate}}"
                 bindinput="onEngagementInput" />
        </view>
      </view>
    </view>

    <!-- 计算结果 -->
    <view class="result-card" wx:if="{{calcResult}}">
      <view class="result-main">
        <view class="result-label">建议报价</view>
        <view class="result-price text-primary">¥{{calcResult.suggest}}</view>
        <view class="result-range text-gray">合理区间：¥{{calcResult.low}} ~ ¥{{calcResult.high}}</view>
      </view>
      
      <view class="result-detail">
        <view class="detail-row-sm">
          <text class="dr-label">内容系数</text>
          <text class="dr-value">{{calcResult.multiplierText}}</text>
        </view>
        <view class="detail-row-sm">
          <text class="dr-label">粉丝加成</text>
          <text class="dr-value">{{calcResult.followerBonusText}}</text>
        </view>
        <view class="detail-row-sm">
          <text class="dr-label">互动加成</text>
          <text class="dr-value">{{calcResult.engBonusText}}</text>
        </view>
      </view>

      <view class="copy-quote-btn" bindtap="copyQuote">📋 复制报价单</view>
    </view>

    <!-- 快速套用模板 -->
    <view class="section-card" wx:if="{{templates.length > 0}}">
      <view class="section-title">📌 快速套用模板</view>
      <view class="template-list">
        <view class="template-item"
              wx:for="{{templates}}"
              wx:key="id"
              data-id="{{item.id}}"
              bindtap="applyTemplate">
          <view class="tpl-left">
            <view class="tpl-name">{{item.name}}</view>
            <view class="tpl-desc text-gray">{{item.desc || '点击套用基础报价'}}</view>
          </view>
          <view class="tpl-right">
            <view class="tpl-price text-money">¥{{item.basePrice}}</view>
            <view class="tpl-del"
                  catchtap="deleteTemplate"
                  data-id="{{item.id}}">删除</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 报价参考系数说明 -->
    <view class="section-card">
      <view class="section-title">📖 计算说明</view>
      <view class="tip-list">
        <view class="tip-item">
          <text class="tip-icon">📷</text>
          <text class="tip-text">图文笔记：1x 基础系数</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">🎥</text>
          <text class="tip-text">视频笔记：2.5x 基础系数</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">📺</text>
          <text class="tip-text">直播带货：5x 基础系数</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">📊</text>
          <text class="tip-text">互动率≥5%：报价+20%；≥3%：+10%</text>
        </view>
        <view class="tip-item">
          <text class="tip-icon">👥</text>
          <text class="tip-text">每10万粉丝：报价+5%</text>
        </view>
      </view>
    </view>

    <!-- 添加模板按钮 -->
    <view class="add-template-area">
      <view class="add-tpl-btn" bindtap="showAddTemplateModal">+ 添加报价模板</view>
    </view>

    <view style="height:40rpx"></view>
  </scroll-view>

  <!-- 添加模板弹窗 -->
  <view class="modal-mask" wx:if="{{showAddTemplate}}" bindtap="hideAddTemplate"></view>
  <view class="modal-panel" wx:if="{{showAddTemplate}}">
    <view class="modal-title">添加报价模板</view>
    <view class="form-group">
      <view class="form-label required">模板名称</view>
      <input class="form-input" placeholder="如：视频种草" data-field="name" bindinput="onTemplateInput" value="{{newTemplate.name}}" />
    </view>
    <view class="form-group">
      <view class="form-label required">基础报价（元）</view>
      <view class="input-prefix-wrap">
        <text class="input-prefix">¥</text>
        <input class="form-input input-with-prefix" type="digit" placeholder="基础报价" data-field="basePrice" bindinput="onTemplateInput" value="{{newTemplate.basePrice}}" />
      </view>
    </view>
    <view class="form-group">
      <view class="form-label">备注说明</view>
      <input class="form-input" placeholder="可选" data-field="desc" bindinput="onTemplateInput" value="{{newTemplate.desc}}" />
    </view>
    <view class="modal-btns">
      <view class="modal-btn cancel" bindtap="hideAddTemplate">取消</view>
      <view class="modal-btn confirm" bindtap="saveTemplate">保存</view>
    </view>
  </view>
</view>
