/* 全局样式 */
page { background: #f5f5f5; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; color: #333; font-size: 28rpx; line-height: 1.5; }

/* 通用 */
.text-primary { color: #FF2442; }
.text-money { color: #FF2442; font-weight: 600; }
.text-gray { color: #999; }
.text-green { color: #52c41a; }

/* 按钮 */
button::after { border: none; }
